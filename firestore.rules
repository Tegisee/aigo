rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 공유 상품 가격 데이터: 인증 사용자 읽기/생성
    // 클라이언트 업데이트: trackerCount (등록/삭제), purchaseCount (구매 기록)
    // 가격 업데이트는 Admin SDK (가격 체크 봇) — rules 무관
    match /shared_products/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['trackerCount', 'purchaseCount']);
    }

    // 유저 문서: 본인만 읽기/쓰기
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // 상품 서브컬렉션: 본인만 접근 (목표가/설정만 저장)
      match /items/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 그 외 모든 문서 접근 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
