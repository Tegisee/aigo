# 쿠팡 파트너스 API 키 (partners.coupang.com에서 발급)
EXPO_PUBLIC_COUPANG_ACCESS_KEY=your_access_key_here
EXPO_PUBLIC_COUPANG_SECRET_KEY=your_secret_key_here

# 공공데이터포털 API 키 (data.go.kr에서 발급)
EXPO_PUBLIC_DATA_GO_KR_KEY=your_api_key_here

# 복지로 API 키 (별도 발급 시, 없으면 DATA_GO_KR_KEY 사용)
EXPO_PUBLIC_WELFARE_API_KEY=your_welfare_api_key_here
